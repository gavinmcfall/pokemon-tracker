{
  "name": "livingdex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Living Dex tracker — Hono API, PokéAPI seed job, and static web front-end",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "preview": "tsx scripts/preview.ts",
    "start": "node dist/server.js",
    "seed": "tsx src/seed/run.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "hono": "^4.7.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}

# livingdex-web: nginx serving the static front-end, proxying /api.
# Uses the unprivileged nginx image so it runs as a non-root user and binds an
# unprivileged port (8080) — no root, no writable rootfs needed.
# When the front-end gains a build step, add a build stage and COPY its output.
FROM nginxinc/nginx-unprivileged:1.27-alpine
ENV API_UPSTREAM=livingdex-api:8080
COPY web/nginx/default.conf.template /etc/nginx/templates/default.conf.template
COPY web/public /usr/share/nginx/html
EXPOSE 8080
